<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-12-2"></div>

    <div class="col-12-8 my-3">
      <h1 class="text-center">Faça o cadastro de um contato</h1>
      
      <%- include('./includes/message') %>
      <div class="row">

        <div class="col-12 my-5">

          <h4>Cadastro</h4>
          <p>Preecha o formulário abaixo para criar um novo contato:</p>

          <form class="form-cadastro" action="/contatos/create" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken%>">
            <div class="form-group">
              <label>Nome</label>
              <input type="text" class="form-control" name="name">
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" class="form-control" name="email">
            </div>
            <div class="form-group">
              <label>Telefone</label>
              <input type="text" class="form-control" name="cel">
            </div>
            <button type="submit" class="btn btn-primary btn-login">Criar minha conta</button>
          </form>

        </div>
      </div>
    </div>
    <div class="col-12-2"></div>
  </div>
</div>

<%- include('includes/footer') %>